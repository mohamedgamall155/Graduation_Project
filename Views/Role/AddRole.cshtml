@model projectweb.ViewModel.RoleViewModel

@{
    ViewData["Title"] = "Add Role";
}

<h2 class="mb-4">Add New Role</h2>

<form asp-action="AddRole" method="post">

    <!-- Validation Summary -->
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="form-group mb-3">
        <label asp-for="RoleType" class="form-label"></label>
        <input asp-for="RoleType" class="form-control" placeholder="Enter role name" />
        <span asp-validation-for="RoleType" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">
        Add Role
    </button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
